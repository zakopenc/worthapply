# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Google Gemini AI (for job analysis, resume tailoring, cover letters, chatbot)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# PostHog (Product Analytics + Funnels)
# Required for Marky's conversion tracking dashboard. No-ops gracefully if unset.
# Provision a project at https://us.posthog.com and paste the project API key below.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: separate server-side key (defaults to NEXT_PUBLIC_POSTHOG_KEY if unset)
# POSTHOG_API_KEY=phc_your_project_key_here

# Environment
NODE_ENV=production
